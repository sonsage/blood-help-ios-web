{
  "version": 2,
  "routes": [
    {
      "src": "/api/xcevent",
      "dest": "/api/xcevent.js"
    },
    {
      "src": "/api/xcevent\\?(.*)",
      "dest": "/api/xcevent.js?$1"
    },
    {
      "src": "/(app\\.js|styles\\.css|manifest\\.webmanifest|service-worker\\.js|icon\\.svg)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
