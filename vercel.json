{
  "version": 2,
  "builds": [
    {
      "src": "api/xcevent.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "manifest.webmanifest",
      "use": "@vercel/static"
    },
    {
      "src": "service-worker.js",
      "use": "@vercel/static"
    },
    {
      "src": "icon.svg",
      "use": "@vercel/static"
    },
    {
      "src": "robots.txt",
      "use": "@vercel/static"
    },
    {
      "src": "sitemap.xml",
      "use": "@vercel/static"
    },
    {
      "src": "googlee75dee753962767f.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/xcevent",
      "dest": "/api/xcevent.js"
    },
    {
      "src": "/api/xcevent\\?(.*)",
      "dest": "/api/xcevent.js?$1"
    },
    {
      "src": "/(app\\.js|styles\\.css|manifest\\.webmanifest|service-worker\\.js|icon\\.svg|robots\\.txt|sitemap\\.xml|googlee75dee753962767f\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
